{
  "name": "nexastory-tauri",
  "version": "0.3.0",
  "private": true,
  "description": "NexaStory - AI-powered creative writing assistant (100% Desktop, 100% Offline)",
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint .",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build --target x86_64-pc-windows-msvc --bundles nsis,msi",
    "tauri:build:native": "tauri build --target x86_64-pc-windows-msvc --bundles nsis,msi -- --features llama-native",
    "tauri:build:cuda": "tauri build --target x86_64-pc-windows-msvc --bundles nsis,msi -- --features llama-cuda",
    "tauri:build:vulkan": "tauri build --target x86_64-pc-windows-msvc --bundles nsis,msi -- --features llama-vulkan",
    "build:cpu": "cd src-tauri && cargo build --release --target x86_64-pc-windows-msvc",
    "build:rust:cuda": "cd src-tauri && cargo build --release --target x86_64-pc-windows-msvc --features llama-cuda",
    "build:rust:vulkan": "cd src-tauri && cargo build --release --target x86_64-pc-windows-msvc --features llama-vulkan",
    "build:release": "bun run scripts/build-release.ts"
  },
  "dependencies": {
    "@radix-ui/react-alert-dialog": "^1.1.14",
    "@radix-ui/react-collapsible": "^1.1.11",
    "@radix-ui/react-dialog": "^1.1.14",
    "@radix-ui/react-dropdown-menu": "^2.1.15",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-popover": "^1.1.14",
    "@radix-ui/react-progress": "^1.1.7",
    "@radix-ui/react-scroll-area": "^1.2.9",
    "@radix-ui/react-select": "^2.2.5",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slider": "^1.3.5",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-switch": "^1.2.5",
    "@radix-ui/react-tabs": "^1.1.12",
    "@radix-ui/react-tooltip": "^1.2.7",
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-dialog": "^2.6.0",
    "@tauri-apps/plugin-fs": "^2.4.5",
    "@tauri-apps/plugin-shell": "^2.3.5",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.23.2",
    "lucide-react": "^0.525.0",
    "next": "^16.1.1",
    "next-themes": "^0.4.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sonner": "^2.0.6",
    "tailwind-merge": "^3.3.1",
    "tailwindcss-animate": "^1.0.7",
    "zustand": "^5.0.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@tauri-apps/cli": "^2.10.1",
    "@types/node": "25.5.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "^16.1.1",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.3.5",
    "typescript": "^5"
  }
}
